# =============================================================================
# .env — 备份工具环境变量配置
# 复制此文件为 .env 并按需修改
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# 【基础备份配置】
# ─────────────────────────────────────────────────────────────────────────────

# 备份源目录，多个目录用英文逗号分隔
# 示例: /data/mysql,/data/redis,/data/app
BACKUP_DIRS=/data

# 本地备份文件存储路径（容器内路径，通过 volumes 映射到宿主机）
BACKUP_DEST=/backup

# 备份压缩包的文件名前缀
# 最终文件名格式为: {前缀}_{时间戳}.tar.{压缩扩展名}
# 示例: myapp_20240101_020000.tar.gz
BACKUP_PREFIX=backup

# 时间戳格式（使用 strftime 语法）
# 默认: %Y%m%d_%H%M%S  =>  20240101_020000
# 仅日期: %Y%m%d        =>  20240101
BACKUP_TIMESTAMP=%Y%m%d_%H%M%S

# 压缩格式: gz | bz2 | xz | zst
# gz  — 速度最快，兼容性最好（推荐）
# bz2 — 压缩率较高，速度较慢
# xz  — 压缩率最高，速度最慢，内存占用大
# zst — 兼顾速度与压缩率（需要 zstd 工具）
BACKUP_COMPRESS=gz

# 是否为每个源目录单独打包（true/false）
# true  — 每个目录单独生成一个压缩包，文件名自动附加目录名
# false — 所有目录打包到一个压缩包（默认）
BACKUP_SEPARATE=false

# ─────────────────────────────────────────────────────────────────────────────
# 【本地备份轮转】
# ─────────────────────────────────────────────────────────────────────────────

# 本地保留最新备份的数量，超出数量的旧备份将自动删除
# 建议值: 7（保留最近 7 份）
BACKUP_RETENTION=7

# ─────────────────────────────────────────────────────────────────────────────
# 【定时任务配置】
# ─────────────────────────────────────────────────────────────────────────────

# Cron 表达式（5段格式）
# 格式: 分 时 日 月 周
# 每天凌晨 2 点:    0 2 * * *
# 每 6 小时一次:    0 */6 * * *
# 每周日凌晨 3 点:  0 3 * * 0
# 每月 1 日 0 点:   0 0 1 * *
BACKUP_CRON=0 2 * * *

# 容器启动时是否立即执行一次备份（true/false）
# true  — 容器启动后马上执行一次，然后按 Cron 计划执行
# false — 仅按 Cron 计划执行（默认）
BACKUP_RUN_ON_START=false

# ─────────────────────────────────────────────────────────────────────────────
# 【时区配置】
# ─────────────────────────────────────────────────────────────────────────────

# 容器时区（影响 Cron 执行时间和日志时间戳）
# 常用值: Asia/Shanghai | Asia/Tokyo | UTC | America/New_York
TZ=Asia/Shanghai

# ─────────────────────────────────────────────────────────────────────────────
# 【远程存储配置】
# ─────────────────────────────────────────────────────────────────────────────

# 远程存储类型: disabled | webdav | s3
# disabled — 不上传到远程，仅本地备份
# webdav   — 上传到 WebDAV 服务（OpenList / Nextcloud / 其他 WebDAV）
# s3       — 上传到 S3 兼容存储（AWS S3 / MinIO / Cloudflare R2 / 阿里云 OSS 等）
REMOTE_TYPE=disabled

# 远程存储保留最新备份数量（超出将自动删除旧备份）
REMOTE_RETENTION=7

# ─── WebDAV 配置 ─────────────────────────────────────────────────────────────
# 仅当 REMOTE_TYPE=webdav 时生效

# WebDAV 服务的根地址（OpenList 默认路径为 /dav）
# 示例: http://192.168.1.100:5244/dav
#       https://list.example.com/dav
WEBDAV_URL=http://your-openlist-host:5244/dav

# WebDAV 认证用户名
WEBDAV_USER=admin

# WebDAV 认证密码
WEBDAV_PASS=your_password

# WebDAV 远程存储目录（相对于 WebDAV 根路径）
# 示例: /backups       => {WEBDAV_URL}/backups/
#       /server/backup => {WEBDAV_URL}/server/backup/
WEBDAV_PATH=/backups

# WebDAV 服务商类型（影响 rclone 兼容性）
# 可选: other（通用，默认） | nextcloud | owncloud | opensuse
WEBDAV_VENDOR=other

# ─── S3 / S3 兼容存储配置 ────────────────────────────────────────────────────
# 仅当 REMOTE_TYPE=s3 时生效

# S3 自定义端点（使用 AWS S3 官方服务可留空）
# MinIO 示例:           http://192.168.1.100:9000
# Cloudflare R2 示例:   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# 阿里云 OSS 示例:      https://oss-cn-hangzhou.aliyuncs.com
# 腾讯云 COS 示例:      https://cos.ap-guangzhou.myqcloud.com
S3_ENDPOINT=

# S3 Access Key（阿里云为 AccessKey ID）
S3_ACCESS_KEY=your_access_key

# S3 Secret Key（阿里云为 AccessKey Secret）
S3_SECRET_KEY=your_secret_key

# S3 存储桶名称
S3_BUCKET=your-bucket-name

# S3 存储桶内的目录路径（末尾不加斜杠）
# 示例: backups/server1
S3_PATH=backups

# S3 区域（AWS 需要设置；MinIO / R2 可填 auto 或 us-east-1）
S3_REGION=us-east-1

# S3 存储类型（AWS 专用，其他兼容存储一般使用 STANDARD）
# 可选: STANDARD | STANDARD_IA | GLACIER | DEEP_ARCHIVE
S3_STORAGE_CLASS=STANDARD

# S3 服务商类型（告知 rclone 做针对性优化）
# 可选: AWS | Minio | Cloudflare | Alibaba | TencentCOS | Other（默认）
S3_PROVIDER=Other

# ─────────────────────────────────────────────────────────────────────────────
# 【通知配置（可选）】
# ─────────────────────────────────────────────────────────────────────────────

# Webhook 通知地址（支持飞书、钉钉、Slack 等格式）
# 飞书机器人示例: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
# 钉钉机器人示例: https://oapi.dingtalk.com/robot/send?access_token=xxxxx
# 留空表示不发送通知
NOTIFY_WEBHOOK=

# 备份成功时是否发送通知（true/false）
NOTIFY_ON_SUCCESS=false

# 备份失败时是否发送通知（true/false）
NOTIFY_ON_FAILURE=true
