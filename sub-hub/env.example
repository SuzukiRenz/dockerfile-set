# Copy this file to .env and fill in your values.
# docker compose automatically loads .env from the project directory.

# ── Required ──────────────────────────────────────────────────────────────────
# Secret token – clients must pass this as ?token=TOKEN in the subscription URL.
TOKEN=change-me-please

# ── Optional ──────────────────────────────────────────────────────────────────
# External port the subscription server listens on.
PORT=8080

# Filename hint sent to subscription clients.
SUB_NAME=My Subscription
